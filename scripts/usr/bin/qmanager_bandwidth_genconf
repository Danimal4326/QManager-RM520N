#!/bin/sh
# =============================================================================
# qmanager_bandwidth_genconf — Generate bridge_traffic_monitor config
# =============================================================================
# Reads settings from JSON config (/etc/qmanager/qmanager.conf) and writes
# the config file that the bridge_traffic_monitor_rm551 binary expects.
#
# Called by qmanager-bandwidth-genconf.service before starting the binary.
#
# Install location: /usr/bin/qmanager_bandwidth_genconf
# =============================================================================

[ -f /usr/lib/qmanager/config.sh ] && . /usr/lib/qmanager/config.sh

CONF_DIR="/etc/quecmanager/settings"
CONF_FILE="$CONF_DIR/bridge_traffic_monitor.conf"

# Read settings from JSON config
refresh_rate_ms=$(qm_config_get bridge_monitor refresh_rate_ms 1000)
ws_port=$(qm_config_get bridge_monitor ws_port 8838)
interfaces=$(qm_config_get bridge_monitor interfaces "br-lan,eth0,rmnet_data0,rmnet_data1,rmnet_ipa0")
channel=$(qm_config_get bridge_monitor channel "network-monitor")
json_mode=$(qm_config_get bridge_monitor json_mode "yes")

# Ensure config directory exists
mkdir -p "$CONF_DIR"

# Write config file
cat > "$CONF_FILE" << EOF
output_path=/tmp/quecmanager/bridge_traffic_monitor
minimal_mode=no
json_mode=${json_mode}
channel=${channel}
refresh_rate_ms=${refresh_rate_ms}
required_interfaces=${interfaces}
websocat_enabled=yes
websocat_url=ws://localhost:${ws_port}
EOF

exit 0
