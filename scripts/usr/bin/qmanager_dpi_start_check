#!/bin/sh
# =============================================================================
# qmanager_dpi_start_check — DPI Service Pre-Start Validation (RM520N-GL)
# =============================================================================
# Called by qmanager-dpi.service ExecStartPre.
# Verifies DPI is enabled, binary exists, and kernel NFQUEUE is available.
# Exit 1 = skip start; exit 0 = proceed.
#
# Install location: /usr/bin/qmanager_dpi_start_check
# =============================================================================

[ -f /usr/lib/qmanager/config.sh ] && . /usr/lib/qmanager/config.sh
[ -f /usr/lib/qmanager/dpi_helper.sh ] && . /usr/lib/qmanager/dpi_helper.sh

vo_enabled=$(qm_config_get video_optimizer enabled 0)
masq_enabled=$(qm_config_get traffic_masquerade enabled 0)

# Neither mode enabled — skip start
[ "$vo_enabled" = "1" ] || [ "$masq_enabled" = "1" ] || exit 1

# Binary must exist and be executable
dpi_check_binary || exit 1

# Kernel NFQUEUE support must be available
dpi_check_kmod || exit 1

exit 0
